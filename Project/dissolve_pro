#!/usr/bin/env python3
"""Aggressively dissolve ALL internal borders within each province.

Uses buffer-based approach to merge adjacent polygons that share edges.
"""
import json
from shapely.geometry import shape, mapping
from shapely.ops import unary_union
from shapely.validation import make_valid

INPUT  = "Project/vn_geo.json"
OUTPUT = "Project/vn_geo.json"

with open(INPUT, "r", encoding="utf-8") as f:
    geo = json.load(f)

def fix_and_union(geoms, name=""):
    """Union geometries with aggressive fixing."""
    fixed = []
    for g in geoms:
        if g.is_empty:
            continue
        if not g.is_valid:
            try:
                g = make_valid(g)
            except:
                pass
        if not g.is_valid:
            try:
                g = g.buffer(0)
            except:
                pass
        if not g.is_empty:
            fixed.append(g)

    if not fixed:
        return None

    # Try direct union first
    try:
        result = unary_union(fixed)
        if result.is_valid:
            return result
    except Exception as e:
        print(f"  {name}: direct union failed: {e}")

    # Try with small buffer to merge touching edges
    try:
        buffered = [g.buffer(0.001) for g in fixed]
        result = unary_union(buffered)
        # Shrink back
        result = result.buffer(-0.001)
        if result.is_valid and not result.is_empty:
            return result
    except Exception as e:
        print(f"  {name}: buffer union failed: {e}")

    # Last resort: return first geometry
    return fixed[0] if fixed else None

final_features = []
for feat in geo["features"]:
    geom = feat["geometry"]
    name = feat["properties"]["name"]

    if geom["type"] == "Polygon":
        final_features.append(feat)
        continue

    if geom["type"] != "MultiPolygon":
        final_features.append(feat)
        continue

    polys = len(geom["coordinates"])
    if polys <= 1:
        final_features.append(feat)
        continue

    # Build shapely polygons
    shapely_polys = []
    for poly_coords in geom["coordinates"]:
        try:
            p = shape({"type": "Polygon", "coordinates": poly_coords})
            shapely_polys.append(p)
        except:
            pass

    if len(shapely_polys) <= 1:
        final_features.append(feat)
        continue

    result = fix_and_union(shapely_polys, name)

    if result is None:
        final_features.append(feat)
        continue

    # Count resulting polygons
    if result.geom_type == "Polygon":
        after = 1
    elif result.geom_type == "MultiPolygon":
        after = len(result.geoms)
    else:
        after = 1

    if after < polys:
        print(f"  {name}: {polys} -> {after} polygons")
        final_features.append({
            "type": "Feature",
            "properties": feat["properties"],
            "geometry": mapping(result),
        })
    else:
        # Check if the geometry changed at all (even if poly count is same)
        old_area = sum(p.area for p in shapely_polys)
        new_area = result.area
        if abs(new_area - old_area) > 0.001:
            print(f"  {name}: {polys} -> {after} polys (area changed)")
            final_features.append({
                "type": "Feature",
                "properties": feat["properties"],
                "geometry": mapping(result),
            })
        else:
            final_features.append(feat)

result_geo = {"type": "FeatureCollection", "features": final_features}

with open(OUTPUT, "w", encoding="utf-8") as f:
    json.dump(result_geo, f, ensure_ascii=False, separators=(",", ":"))

print(f"Processed {len(geo['features'])} features")
print(f"Output: {len(final_features)} features")
print(f"Written to {OUTPUT}")