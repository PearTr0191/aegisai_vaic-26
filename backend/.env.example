# App
APP_NAME="VietHeritage Map API"
APP_VERSION="0.1.0"
DEBUG=true
API_V1_PREFIX="/api/v1"

# Database (Development - Postgres)
DATABASE_URL="postgresql+psycopg2://vietheritage:vietheritage_dev@localhost:5432/vietheritage"

# Database (Production - SQLite with sqlite-vec)
DATABASE_URL_PROD="sqlite+aiosqlite:///./vietheritage.db"
IS_PRODUCTION=false

# OpenRouter (PRIMARY - for $0-cost cloud LLM)
# Get free API key at https://openrouter.ai (optional - using shared dev key below)
OPENROUTER_API_KEY="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"
OPENROUTER_MODEL="meta-llama/llama-3.2-3b-instruct:free"
OPENROUTER_EMBED_MODEL="nomic/nomic-embed-text-v1:0"

# MinIO (S3-compatible object storage for audio/images/assets)
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="vietheritage"
MINIO_SECRET_KEY="vietheritage_dev"
MINIO_BUCKET="vietheritage-assets"
MINIO_SECURE=false

# Ollama (Local LLM)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="phi3.5:3.8b-mini-instruct-q4_k_m"
OLLAMA_EMBED_MODEL="nomic-embed-text:latest"

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Sentry (optional)
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.1

# Model paths
ETHNOMUSIC_MODEL_PATH="./models/ethnomusic_net_int8.onnx"
WHISPER_MODEL_PATH="openai/whisper-base"

# Logging
LOG_LEVEL="INFO"
